# ─────────────────────────────────────────────────────────────────
# Get Mumm — Environment Variables Reference
# Copy this file to .env (or per-environment files) and fill values.
# NEVER commit real secrets to source control.
# ─────────────────────────────────────────────────────────────────

# ── Frontend (Vite / React) ─────────────────────────────────────
# URL of the ASP.NET Core API (empty = same-origin proxy in dev)
VITE_API_URL=http://localhost:8080

# Supabase project URL (public, safe to expose)
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co

# Supabase anon/public key (public, safe to expose)
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ── Backend (ASP.NET Core) ──────────────────────────────────────
# Kestrel listen port
PORT=8080

# PostgreSQL connection string (Supabase pooler recommended)
DATABASE_URL=postgresql://postgres.<project-id>:<password>@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# Supabase service-role key (SECRET — server-side only)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Stripe secret key (optional — needed for card payments)
STRIPE_SECRET_KEY=<your-stripe-secret-key>

# ── Node (legacy / tooling) ─────────────────────────────────────
NODE_ENV=development
