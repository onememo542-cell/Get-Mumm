{
  "version": 2,
  "name": "get-mumm-backend",
  "builds": [
    {
      "src": "backend/package.json",
      "use": "@vercel/node@3.x",
      "config": {
        "zeroConfig": true,
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/dist/index.mjs"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "PORT": "3000"
  },
  "buildCommand": "cd backend && pnpm install && pnpm build",
  "startCommand": "node backend/dist/index.mjs",
  "outputDirectory": "backend/dist",
  "framework": "express"
}
