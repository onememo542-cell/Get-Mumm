{
  "version": 2,
  "buildCommand": "cd backend && npm install && npm run build",
  "installCommand": "npm install",
  "devCommand": "cd backend && npm run dev",
  "functions": {
    "api/handler.mjs": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api(.*)",
      "destination": "/api/handler.mjs"
    },
    {
      "source": "/health",
      "destination": "/api/handler.mjs"
    },
    {
      "source": "/",
      "destination": "/api/handler.mjs"
    }
  ]
}
