{
  "version": 2,
  "name": "get-mumm-backend",
  "buildCommand": "cd backend && pnpm install && pnpm build",
  "outputDirectory": "backend/dist",
  "regions": ["sfo1"],
  "functions": {
    "backend/dist/index.mjs": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "env": {
    "NODE_ENV": "production",
    "LOG_LEVEL": "info"
  }
}
