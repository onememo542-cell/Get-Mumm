{
  "version": 2,
  "name": "get-mumm-backend",
  "builds": [
    {
      "src": "backend/package.json",
      "use": "@vercel/node@3.x"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/src/index.ts"
    }
  ],
  "outputDirectory": "backend/dist",
  "env": {
    "NODE_ENV": "production"
  }
}
