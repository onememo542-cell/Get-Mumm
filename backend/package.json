{
  "name": "get-mumm-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "node --env-file=.env --import tsx src/db/migrate.ts",
    "seed": "node --env-file=.env --import tsx src/db/seed.ts",
    "push": "node --env-file=.env node_modules/.bin/drizzle-kit push"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "*",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "pg": "^8.21.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "*",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "*"
  }
}
